      "titre": "Génération de code",
      "categorie": "code",
      "version": "1.0",
      "date": "2026-04-13",
      "modeles_cibles": ["GPT-4o", "Claude 3.5 Sonnet", "Gemini 1.5 Pro"],
      "description": "Génère un bloc de code propre, commenté et fonctionnel dans le langage demandé à partir d'une description fonctionnelle en langage naturel.",
      "domaines": ["développement logiciel", "scripting", "automatisation", "génération de fonctions utilitaires"],
      "parametres_modele": {
        "temperature": 0.2,
        "max_tokens": 2048,
        "top_p": 0.95,
        "frequency_penalty": 0.0
      },
      "variables": [
        {
          "nom": "{{langage}}",
          "type": "string",
          "obligatoire": true,
          "description": "Langage de programmation cible",
          "exemple": "Python 3.11"
        },
        {
          "nom": "{{description_fonctionnelle}}",
          "type": "string",
          "obligatoire": true,
          "description": "Ce que doit faire la fonction en langage naturel",
          "exemple": "lit un fichier CSV et retourne un dictionnaire"
        },
        {
          "nom": "{{style_code}}",
          "type": "string",
          "obligatoire": false,
          "description": "Convention de style à respecter",
          "exemple": "PEP 8"
        },
        {
          "nom": "{{gestion_erreurs}}",
          "type": "string",
          "obligatoire": false,
          "description": "Stratégie de gestion des erreurs",
          "exemple": "lever des exceptions explicites"
        },
        {
          "nom": "{{contraintes_supplementaires}}",
          "type": "string",
          "obligatoire": false,
          "description": "Contraintes additionnelles libres",
          "exemple": "- Sans dépendances externes"
        }
      ],
      "mots_cles": ["code", "programmation", "développement", "fonction", "script", "Python", "JavaScript"]
    },
